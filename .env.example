# Atelier — environment configuration (Week-1 walking skeleton)
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
#
# Atelier is a standalone Next.js app that connects to evergreen-core's
# existing SHARED Postgres (the "model-radar pattern"). It does NOT run its
# own database — it talks to the same Evergreen DB over DATABASE_URL.

# ---------------------------------------------------------------------------
# Database (REQUIRED) — the shared Evergreen Postgres
# ---------------------------------------------------------------------------
# postgres-js connection string. Point this at the same Postgres instance
# that evergreen-core / apps/model-radar use. Atelier's tables are namespaced
# with the `atelier_` prefix and live alongside the existing Evergreen schema.
#   Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgres://evergreen:evergreen@127.0.0.1:5432/evergreen

# ---------------------------------------------------------------------------
# Workspace (REQUIRED) — the single seeded workspace constant
# ---------------------------------------------------------------------------
# Auth is deferred in Week 1 (LAN / Tailscale-local). Every table carries a
# workspace_id and we scope everything to this one seeded workspace. This MUST
# match the ATELIER_WS constant baked into the app/seed and never change.
ATELIER_WS=00000000-0000-0000-0000-000000000a11

# ---------------------------------------------------------------------------
# OpenCode (OPTIONAL) — the local agent runner on M90t
# ---------------------------------------------------------------------------
# Endpoint for dispatching a scoped OpenCode build chunk. If reachable, the
# client POSTs here; otherwise it falls back to shelling out over ssh.
ATELIER_OPENCODE_URL=http://127.0.0.1:4096

# When set to 1, lib/opencode-client.ts returns a stub { ok:true, note:"stub" }
# instead of actually dispatching a chunk. Recommended for the walking-skeleton
# acceptance run. Set to 0 (or unset) to hit the real OpenCode runner.
ATELIER_OPENCODE_STUB=1
